#!/usr/bin/env bash
# pre-push hook — KB drift check (cảnh báo sớm trên máy dev, KHÔNG chặn push).
# Cài bằng: kb ci   (copy file này vào .git/hooks/pre-push)
#
# Lưu ý: .kb-local/ giờ là symlink trỏ về KB trung tâm
# (projects/<tên-project>/.kb-local/). Pre-push local chạy được nhờ symlink đã link.
#
# Muốn CHẶN push khi có drift: đổi dòng cuối thành:
#     exec bash "$CHECK" "origin/main" --strict
CHECK="$(git rev-parse --show-toplevel)/.kb-local/ci/kb-drift-check.sh"
if [ -x "$CHECK" ]; then
  bash "$CHECK" "origin/main"
fi
exit 0   # advisory: luôn cho push. (Dùng --strict ở trên để chặn.)
